# ──────────────────────────────────────────────────────────────────────────
# EventBookingSystem — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────
DB_PASSWORD=

# ── MongoDB (optional — leave MONGODB_ENABLED=false if not installed) ─────
MONGODB_ENABLED=false
MONGODB_URI=mongodb://localhost:27017/event_booking_logs

# ── JWT ───────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use a random string in production.
JWT_SECRET=

# ── Gmail SMTP ────────────────────────────────────────────────────────────
# Create a 16-char App Password:
# Google Account → Security → 2-Step Verification → App Passwords
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Razorpay ──────────────────────────────────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR

# ── AI Providers (use at least one) ───────────────────────────────────────
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── App ───────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
