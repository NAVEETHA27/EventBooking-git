# ---------------------------------------------------------------------------
# EventBookingSystem — Environment Variables
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# ── MongoDB (optional) ────────────────────────────────────────────────────────
# Set MONGODB_ENABLED=true to persist notifications, email logs, analytics.
# Leave false if MongoDB is not installed.
MONGODB_ENABLED=false
MONGODB_URI=mongodb://localhost:27017/event_booking_logs

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use a cryptographically random string in production.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Use a 16-character App Password from:
#   Google Account → Security → 2-Step Verification → App Passwords
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_16chars

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get your test keys from https://dashboard.razorpay.com/app/keys
# Test key IDs start with rzp_test_
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
RAZORPAY_CURRENCY=INR

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get API key from https://aistudio.google.com/app/apikey
AI_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# ── pgvector (optional — for vector search) ──────────────────────────────────
# Only needed if VECTOR_DB_PROVIDER=pgvector
VECTOR_DB_PROVIDER=mysql
VECTOR_DB_URL=
VECTOR_DB_USERNAME=
VECTOR_DB_PASSWORD=
